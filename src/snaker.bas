490 '
500 'score
510 CLS RND(4)+1:PRINT@ 168,"YOU MADE IT IN:";
520 SC=HT/60:M$=LEFT$(STR$(INT(SC/60)),3):IF VAL(M$)<1 THEN M$="00"
530 IF LEN(M$)>2 THEN M$=RIGHT$(M$,2)
540 S$=LEFT$(STR$(INT(SC-INT(SC/60)*60)),3):IF LEN(S$)<3 THEN S$="0"+RIGHT$(S$,1) ELSE S$=RIGHT$(S$,2)
550 FOR PP=1312 TO 1343:POKE PP,33:NEXT PP
560 P$=M$+":"+S$:PRINT@ 301,P$;
