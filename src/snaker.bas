250 '
260 'advance snake
270 L=L+32:R=R+32
280 IF L=1441 THEN POKE P,148:P=P+32:POKE P,244:GOTO 380
290 POKE P,148:P=P+32:GOTO 130
300 '
310 'crash
320 L=L-32:R=R-32:IF L<1025 THEN L=1025:R=R+32
330 FOR PL=1 TO 2:PLAY"O2 T2 L8 B":SCREEN0,1:PLAY"L8 E":SCREEN 0,0:NEXT PL
